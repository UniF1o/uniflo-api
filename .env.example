# Database
DATABASE_URL=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_STORAGE_BUCKET=

# Supabase webhook secrets (separate per webhook for least-privilege)
WEBHOOK_SECRET=
DELETE_WEBHOOK_SECRET=

# Observability
SENTRY_DSN=
ENVIRONMENT=development

# CORS — comma-separated list of allowed origins, e.g. http://localhost:3000,https://uniflo-web.vercel.app
CORS_ORIGINS=

# Phase 2+ integrations (unused in Phase 1)
ANTHROPIC_API_KEY=
RESEND_API_KEY=

# Feature flag — set to false when Phase 3 wires real Playwright adapters
FAKE_AUTOMATION=true
